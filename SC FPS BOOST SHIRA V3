-- [[ LOGIKA PENGHANCUR TEKSTUR & BAYANGAN ]] --

local isBoosting = false

local function RemoveTextures()
    -- Pengaturan dasar engine ke level terendah
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    game.Lighting.GlobalShadows = false
    
    -- Menghapus tekstur lama yang sudah ada di map secara bertahap (Mencegah Lag Spike)
    task.spawn(function()
        local allObjects = game:GetDescendants()
        for count, v in pairs(allObjects) do
            if not isBoosting then break end
            
            -- Menghapus gambar tempelan / tekstur tanah bangunan
            if v:IsA("Decal") or v:IsA("Texture") then
                v:Destroy()
            -- Memaksa part menjadi plastik polos tanpa tekstur material (Kayu, Aspal, Bata, dll)
            elseif v:IsA("Part") or v:IsA("MeshPart") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") or v:IsA("WedgePart") then
                v.Material = Enum.Material.SmoothPlastic
                v.Color = Color3.fromRGB(130, 130, 130) -- Meratakan warna objek menjadi abu-abu netral
            -- Mematikan efek partikel
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") then
                v:Destroy()
            end
            
            if count % 250 == 0 then task.wait() end -- Jeda per 250 objek agar tidak patah-patah
        end
    end)
end

-- Interaksi Klik Tombol Toggle
ToggleBtn.MouseButton1Click:Connect(function()
    isBoosting = not isBoosting
    
    if isBoosting then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ToggleBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
        ToggleBtn.Text = "TEXTURES PURGED"
        StatusLabel.Text = "// TEXTURE: POTATO_MODE_ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        UIStroke.Color = Color3.fromRGB(255, 255, 255)
        RemoveTextures()
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        ToggleBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        ToggleBtn.Text = "REMOVE ALL TEXTURES"
        StatusLabel.Text = "// TEXTURE: DEFAULT (REJOIN REQ)"
        StatusLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
        UIStroke.Color = Color3.fromRGB(40, 40, 40)
        -- Catatan: Karena aset dihancurkan (:Destroy) demi performa maksimal, lakukan re-join jika ingin mengembalikan map asli.
    end
end)

-- Menghancurkan tekstur baru yang baru saja di-load oleh server saat permainan berjalan
game.DescendantAdded:Connect(function(v)
    if isBoosting then
        if v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") then
            task.wait()
            v:Destroy()
        elseif v:IsA("Part") or v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
        end
    end
end)

-- [[ LOGIKA PENGATURAN TOMBOL SEMBUNYI UI (KEYBIND V) ]] --
local uiVisible = true
local tInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.V then
        uiVisible = not uiVisible
        local targetAlpha = uiVisible and 0 or 1
        
        TweenService:Create(MainFrame, tInfo, {BackgroundTransparency = targetAlpha}):Play()
        TweenService:Create(UIStroke, tInfo, {Transparency = targetAlpha}):Play()
        TweenService:Create(ToggleContainer, tInfo, {BackgroundTransparency = targetAlpha}):Play()
        TweenService:Create(ToggleStroke, tInfo, {Transparency = targetAlpha}):Play()
        TweenService:Create(ToggleBtn, tInfo, {BackgroundTransparency = targetAlpha, TextTransparency = targetAlpha}):Play()
        TweenService:Create(Title, tInfo, {TextTransparency = targetAlpha}):Play()
        TweenService:Create(SubTitle, tInfo, {TextTransparency = targetAlpha}):Play()
        TweenService:Create(StatusLabel, tInfo, {TextTransparency = targetAlpha}):Play()
        TweenService:Create(HideHint, tInfo, {TextTransparency = targetAlpha}):Play()
        
        MainFrame.Active = uiVisible
    end
end)
