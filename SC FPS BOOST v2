-- [[ HARDCORE OPTIMIZATION LOGIC ]] --

local isBoosting = false
local originalData = {}
local postProcessingEffects = {}

-- Fungsi utama penguras grafis ekstrim
local function DeepClean()
    settings().Network.IncomingReplicationLag = -1
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    
    -- Hapus Efek Pencahayaan Berat
    Lighting.GlobalShadows = false
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") or effect:IsA("Bloom") or effect:IsA("Blur") or effect:IsA("DepthOfField") or effect:IsA("SunRays") or effect:IsA("ColorCorrectionEffect") then
            effect.Enabled = false
            table.insert(postProcessingEffects, effect)
        end
    end

    -- Iterasi part & texture secara aman dengan chunking (anti crash)
    task.spawn(function()
        local objects = game:GetDescendants()
        for i, v in pairs(objects) do
            if not isBoosting then break end
            
            if v:IsA("Part") or v:IsA("MeshPart") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") then
                if not originalData[v] then
                    originalData[v] = { Material = v.Material, CastShadow = v.CastShadow }
                end
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
            elseif v:IsA("Decal") or v:IsA("Texture") then
                v.Transparency = 1
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Fire") then
                v.Enabled = false
            end
            
            if i % 300 == 0 then task.wait() end -- Jeda pemrosesan agar FPS stabil saat aktivasi
        end
    end)
end

local function RestoreData()
    Lighting.GlobalShadows = true
    for _, effect in pairs(postProcessingEffects) do
        if effect then effect.Enabled = true end
    end
    table.clear(postProcessingEffects)

    for part, props in pairs(originalData) do
        if part and part.Parent then
            part.Material = props.Material
            part.CastShadow = props.CastShadow
        end
    end
    
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 0
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Fire") then v.Enabled = true end
    end
end

-- Toggle Trigger
ToggleBtn.MouseButton1Click:Connect(function()
    isBoosting = not isBoosting
    
    if isBoosting then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ToggleBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
        ToggleBtn.Text = "HYPER BOOST ACTIVE"
        StatusLabel.Text = "// ENGINE: MAX_OVERCLOCK_POTATO"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        UIStroke.Color = Color3.fromRGB(255, 255, 255)
        DeepClean()
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        ToggleBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
        ToggleBtn.Text = "ACTIVATE HYPER BOOST"
        StatusLabel.Text = "// ENGINE: IDLE"
        StatusLabel.TextColor3 = Color3.fromRGB(120, 120, 120)
        UIStroke.Color = Color3.fromRGB(35, 35, 35)
        RestoreData()
    end
end)

-- Hook untuk objek baru yang di-render saat Anda bermain
game.DescendantAdded:Connect(function(v)
    if isBoosting then
        if v:IsA("Part") or v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.CastShadow = false
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") then
            v.Enabled = false
        end
    end
end)

-- [[ HIDE / SHOW UI SYSTEM (KEYBIND V) ]] --
local uiVisible = true
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.V then
        uiVisible = not uiVisible
        
        local targetTransparency = uiVisible and 0 or 1
        local targetBgTransparency = uiVisible and 0 or 1
        
        -- Animasi memudar mulus untuk menyembunyikan panel
        TweenService:Create(MainFrame, tweenInfo, {BackgroundTransparency = targetBgTransparency}):Play()
        TweenService:Create(UIStroke, tweenInfo, {Transparency = targetTransparency}):Play()
        TweenService:Create(ToggleContainer, tweenInfo, {BackgroundTransparency = targetBgTransparency}):Play()
        TweenService:Create(ToggleStroke, tweenInfo, {Transparency = targetTransparency}):Play()
        TweenService:Create(ToggleBtn, tweenInfo, {BackgroundTransparency = targetBgTransparency, TextTransparency = targetTransparency}):Play()
        TweenService:Create(Title, tweenInfo, {TextTransparency = targetTransparency}):Play()
        TweenService:Create(SubTitle, tweenInfo, {TextTransparency = targetTransparency}):Play()
        TweenService:Create(StatusLabel, tweenInfo, {TextTransparency = targetTransparency}):Play()
        TweenService:Create(HintLabel, tweenInfo, {TextTransparency = targetTransparency}):Play()
        
        -- Menonaktifkan interaksi klik/drag saat tidak terlihat
        MainFrame.Active = uiVisible
    end
end)
