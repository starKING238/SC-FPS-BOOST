-- [[ LOGIKA OPTIMASI ]] --

local _settings = settings()
local isBoosting = false
local originalMaterials = {}
local lightingBackup = {
    GlobalShadows = game.Lighting.GlobalShadows,
    OutdoorAmbient = game.Lighting.OutdoorAmbient
}

local function ApplyFPSBoost()
    game.Lighting.GlobalShadows = false
    game.Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    _settings.Network.IncomingReplicationLag = -1
    
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Part") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") or v:IsA("WedgePart") then
            if not originalMaterials[v] then
                originalMaterials[v] = { Material = v.Material }
            end
            v.Material = Enum.Material.SmoothPlastic
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1 
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") then
            v.Enabled = false 
        end
    end
end

local function RevertGraphics()
    game.Lighting.GlobalShadows = lightingBackup.GlobalShadows
    game.Lighting.OutdoorAmbient = lightingBackup.OutdoorAmbient
    
    for part, props in pairs(originalMaterials) do
        if part and part.Parent then part.Material = props.Material end
    end
    
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 0
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") then v.Enabled = true end
    end
end

-- Interaksi Tombol
ToggleBtn.MouseButton1Click:Connect(function()
    isBoosting = not isBoosting
    
    if isBoosting then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ToggleBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
        ToggleBtn.Text = "SYSTEM OPTIMIZED"
        StatusLabel.Text = "// STATUS: ACTIVE_POTATO_MODE"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        UIStroke.Color = Color3.fromRGB(255, 255, 255)
        ApplyFPSBoost()
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        ToggleBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        ToggleBtn.Text = "INITIALIZE BOOST"
        StatusLabel.Text = "// STATUS: READY_TO_RUN"
        StatusLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
        UIStroke.Color = Color3.fromRGB(40, 40, 40)
        RevertGraphics()
    end
end)

game.DescendantAdded:Connect(function(v)
    if isBoosting then
        if v:IsA("Part") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") or v:IsA("WedgePart") then v.Material = Enum.Material.SmoothPlastic
        elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 1
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") then v.Enabled = false end
    end
end)

-- [[ HIDE / SHOW UI SYSTEM (KEYBIND: V) ]] --
local uiVisible = true
local tInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.V then
        uiVisible = not uiVisible
        local targetAlpha = uiVisible and 0 or 1
        
        TweenService:Create(MainFrame, tInfo, {BackgroundTransparency = targetAlpha}):Play()
        TweenService:Create(UIStroke, tInfo, {Transparency = targetAlpha}):Play()
        TweenService:Create(ToggleContainer, tInfo, {BackgroundTransparency = targetAlpha}):Play()
        TweenService:Create(ToggleStroke, tInfo, {Transparency = targetAlpha}):Play()
        TweenService:Create(ToggleBtn, tInfo, {BackgroundTransparency = targetAlpha, TextTransparency = targetAlpha}):Play()
        TweenService:Create(Title, tInfo, {TextTransparency = targetAlpha}):Play()
        TweenService:Create(SubTitle, tInfo, {TextTransparency = targetAlpha}):Play()
        TweenService:Create(StatusLabel, tInfo, {TextTransparency = targetAlpha}):Play()
        TweenService:Create(HideHint, tInfo, {TextTransparency = targetAlpha}):Play()
        
        MainFrame.Active = uiVisible
    end
end)
