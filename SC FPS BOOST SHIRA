-- [[ HARDCORE OPTIMIZATION LOGIC ]] --

local isBoosting = false
local renderSettings = settings().Rendering

local function PurgeEverything()
    -- 1. Low-Level Core Engine Overclock
    renderSettings.QualityLevel = Enum.QualityLevel.Level01
    renderSettings.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01
    sethiddenproperty(renderSettings, "EagerBulkExecution", true)
    settings().Network.IncomingReplicationLag = -1
    
    -- 2. Membatasi Radius Streaming Data Map
    pcall(function()
        sethiddenproperty(workspace, "StreamingTargetRadius", 32)
        sethiddenproperty(workspace, "StreamingMinDistance", 32)
    end)

    -- 3. Mematikan Total Sistem Pencahayaan & Efek Berat
    Lighting.GlobalShadows = false
    Lighting.OutdoorAmbient = Color3.fromRGB(130, 130, 130)
    Lighting.GeographicLatitude = 0
    pcall(function()
        Lighting.EnvironmentBlurIntensity = 0
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
    
    -- Menghapus paksa efek atmosferik (Blur, SunRays, Bloom, dll.)
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") or effect:IsA("Bloom") or effect:IsA("Blur") or effect:IsA("DepthOfField") or effect:IsA("SunRays") or effect:IsA("ColorCorrectionEffect") or effect:IsA("Atmosphere") then
            effect:Destroy()
        end
    end

    -- 4. Pembersihan Masal Aset Map (Tekstur, Efek Partikel, Bayangan Objek)
    task.spawn(function()
        local descendants = game:GetDescendants()
        for i, v in pairs(descendants) do
            if not isBoosting then break end
            
            -- Hapus Gambar & Tekstur
            if v:IsA("Decal") or v:IsA("Texture") then
                v:Destroy()
            -- Turunkan Kualitas Render Part & Paksa Jadi SmoothPlastic Polos Tanpa Bayangan
            elseif v:IsA("Part") or v:IsA("MeshPart") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") or v:IsA("WedgePart") then
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
            -- Hapus Efek Partikel Penyebab Drop FPS
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Fire") then
                v:Destroy()
            -- Matikan Animasi Pakaian/Jubah Fisika
            elseif v:IsA("ShirtGraphic") or v:IsA("Pants") or v:IsA("Shirt") then
                v:Destroy()
            end
            
            if i % 300 == 0 then task.wait() end
        end
    end)
end

-- Interaksi Klik Tombol Toggle
ToggleBtn.MouseButton1Click:Connect(function()
    isBoosting = not isBoosting
    
