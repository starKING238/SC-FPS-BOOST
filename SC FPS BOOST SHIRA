-- [[ CORE RADICAL OPTIMIZATION ]] --

local isBoosting = false
local renderSettings = settings().Rendering

local function TotalAnnihilation()
    -- Pengaturan Kritis Terendah Engine
    renderSettings.QualityLevel = Enum.QualityLevel.Level01
    renderSettings.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level01
    sethiddenproperty(renderSettings, "EagerBulkExecution", true)
    settings().Network.IncomingReplicationLag = -1
    
    -- Jarak Pandang Super Pendek (Hanya Render Sekitar Karakter)
    pcall(function()
        sethiddenproperty(workspace, "StreamingTargetRadius", 16)
        sethiddenproperty(workspace, "StreamingMinDistance", 16)
    end)

    -- Matikan Pencahayaan Global Total
    Lighting.GlobalShadows = false
    Lighting.OutdoorAmbient = Color3.fromRGB(120, 120, 120)
    pcall(function()
        Lighting.EnvironmentBlurIntensity = 0
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
    
    for _, effect in pairs(Lighting:GetChildren()) do
        effect:Destroy()
    end

    -- Eksekusi Penghancuran Masal Seluruh Objek Map
    task.spawn(function()
        local descendants = game:GetDescendants()
        for i, v in pairs(descendants) do
            if not isBoosting then break end
            
            -- 1. Hapus Semua Jenis Gambar, Iklan, & Decal Map
            if v:IsA("Decal") or v:IsA("Texture") or v:IsA("SurfaceGui") or v:IsA("BillboardGui") then
                v:Destroy()
            
            -- 2. Hancurkan Struktur Mesh Kompleks (Ubah Menjadi Kotak Polos)
            elseif v:IsA("MeshPart") then
                v.MeshId = "" -- Menghapus data render mesh 3D detail
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
                
            -- 3. Ratakan Semua Part Standar
            elseif v:IsA("Part") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") or v:IsA("WedgePart") then
                v.Material = Enum.Material.SmoothPlastic
                v.CastShadow = false
            
            -- 4. Hilangkan Seluruh Partikel Mengambang (Asap, Api, Efek Peluru)
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Fire") then
                v:Destroy()
                
            -- 5. Hapus Aksesoris Pakaian Fisika 3D yang Berat
            elseif v:IsA("ShirtGraphic") or v:IsA("Pants") or v:IsA("Shirt") or v:IsA("Clothing") then
                v:Destroy()
            end
            
            if i % 400 == 0 then task.wait() end -- Diproses sangat cepat per 400 objek
        end
    end)
end

-- Toggle Klik
ToggleBtn.MouseButton1Click:Connect(function()
    isBoosting = not isBoosting
    
    if isBoosting then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
