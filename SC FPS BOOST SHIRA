-- 2. Logika Core Toggle Optimized
local function ToggleOptimization()
    IsOptimized = not IsOptimized
    
    if IsOptimized then
        -- === MODE ON ===
        Status.Text = "SYSTEM: FULLY OPTIMIZED"
        Status.TextColor3 = Color3.fromRGB(75, 255, 75)
        ToggleButton.Text = "DE-OPTIMIZE SYSTEM"
        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(75, 255, 75)}):Play()

        pcall(function() setfpscap(9999) end)
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        Lighting.GlobalShadows = false

        local descendants = Workspace:GetDescendants()
        for i = 1, #descendants do
            local v = descendants[i]
            pcall(function()
                if v:IsA("BasePart") then
                    OriginalAesthetics[v] = {Material = v.Material, Color = v.Color, CastShadow = v.CastShadow}
                    
                    v.Material = Enum.Material.SmoothPlastic
                    v.CastShadow = false
                    
                    -- Sisa warna dikit hanya untuk Karakter Utama & Senjata/Tool
                    if v:IsDescendantOf(LocalPlayer.Character) or v.Parent:IsA("Tool") then
                        v.Color = v.Color 
                    else
                        -- Sisanya (Map, Jalan, Gedung) dibuat abu-abu polos tanpa warna
                        v.Color = Color3.fromRGB(180, 180, 180)
                    end
                    
                elseif v:IsA("Texture") or v:IsA("Decal") then
                    OriginalAesthetics[v] = {Parent = v.Parent}
                    v.Parent = nil 
                elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
                    OriginalAesthetics[v] = {Enabled = v.Enabled}
                    v.Enabled = false
                end
            end)
            if i % 300 == 0 then task.wait() end
        end
    else
        -- === MODE OFF ===
        Status.Text = "SYSTEM: UNOPTIMIZED"
        Status.TextColor3 = Color3.fromRGB(255, 75, 75)
        ToggleButton.Text = "RUN OPTIMIZATION"
        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 75, 75)}):Play()

        pcall(function() setfpscap(60) end)
        Lighting.GlobalShadows = true
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic

        for obj, data in pairs(OriginalAesthetics) do
            pcall(function()
                if obj:IsA("BasePart") then
                    obj.Material = data.Material
                    obj.Color = data.Color
                    obj.CastShadow = data.CastShadow
                elseif obj:IsA("Texture") or obj:IsA("Decal") then
                    obj.Parent = data.Parent
                elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
                    obj.Enabled = data.Enabled
                end
            end)
        end
        OriginalAesthetics = {}
    end
end

ToggleButton.MouseButton1Click:Connect(ToggleOptimization)

-- Real-time Handler saat objek baru masuk ketika status ON
Workspace.DescendantAdded:Connect(function(newObj)
    if IsOptimized then
        task.spawn(function()
            pcall(function()
                if newObj:IsA("BasePart") then
                    OriginalAesthetics[newObj] = {Material = newObj.Material, Color = newObj.Color, CastShadow = newObj.CastShadow}
                    newObj.Material = Enum.Material.SmoothPlastic
                    newObj.CastShadow = false
                    if not (newObj:IsDescendantOf(LocalPlayer.Character) or newObj.Parent:IsA("Tool")) then
                        newObj.Color = Color3.fromRGB(180, 180, 180)
                    end
                elseif newObj:IsA("Texture") or newObj:IsA("Decal") then
                    OriginalAesthetics[newObj] = {Parent = newObj.Parent}
                    newObj.Parent = nil
                elseif newObj:IsA("ParticleEmitter") then
                    OriginalAesthetics[newObj] = {Enabled = newObj.Enabled}
                    newObj.Enabled = false
                end
            end)
        end)
    end
end)
